{
  "mode": "interactive",
  "granularity": "standard",
  "workflow": {
    "research": true,
    "plan_check": true,
    "verifier": true,
    "auto_advance": false,
    "discuss_mode": "discuss",
    "research_before_questions": false,
    "code_review_command": "/makeitso-review",
    "cross_ai_execution": false,
    "cross_ai_command": ""
  },
  "planning": {
    "commit_docs": true,
    "search_gitignored": false
  },
  "parallelization": {
    "enabled": true,
    "plan_level": true,
    "task_level": false,
    "skip_checkpoints": true,
    "max_concurrent_agents": 3
  },
  "gates": {
    "confirm_project": false,
    "confirm_phases": false,
    "confirm_roadmap": false,
    "confirm_breakdown": false,
    "confirm_plan": false,
    "execute_next_plan": false,
    "issues_review": false,
    "confirm_transition": false
  },
  "agent_skills": {
    "gsd-assumptions-analyzer": ["global:product-only-interview", "global:triage-product-vs-technical"],
    "gsd-verifier": ["global:triage-product-vs-technical"],
    "gsd-plan-checker": ["global:triage-product-vs-technical"],
    "gsd-integration-checker": ["global:triage-product-vs-technical"],
    "gsd-executor": ["global:triage-product-vs-technical"],
    "gsd-nyquist-auditor": ["global:triage-product-vs-technical"]
  }
}
